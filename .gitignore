.DS_Store
.AppleDouble
.LSOverride
*.swp
*.swo
*~
.idea/
.vscode/

# Build / dependency / cache output (package-lock.json is intentionally
# tracked, not ignored, so static-site builds are deterministic).
node_modules/
_site/
dist/
.cache/
.tmp/
.eleventy-cache/

# Logs
*.log
logs/

# Local env / secrets
.env
.env.*
*.local

# Local-only media workspace (per-folder .gitignore inside external-media/
# enforces the keep-only-README-and-.gitignore rule for that subtree)
