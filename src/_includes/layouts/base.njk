<!doctype html>
<html lang="{{ site.language or 'en' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} - {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
    {% if description %}<meta name="description" content="{{ description }}">{% endif %}
    <link rel="stylesheet" href="{{ '/assets/css/site.css' | url }}">
  </head>
  <body data-section="{{ section or 'inner' }}"{% if isGateway %} data-gateway="true"{% endif %}>
    {% if isGateway %}
      <div class="gateway">
        <div class="gateway__identity">
          {% include "components/identity-block.njk" %}
        </div>
        <div class="gateway__menu">
          {% include "components/main-menu.njk" %}
        </div>
      </div>
    {% else %}
      <div class="page">
        <aside class="page__side">
          {% include "components/main-menu.njk" %}
          {% include "components/to-main-menu.njk" %}
        </aside>
        <main class="page__content">
          {{ content | safe }}
        </main>
      </div>
    {% endif %}

    <footer class="site-footer">
      <p>
        <strong>Source-authority doctrine.</strong>
        The local reconstruction of archived <code>passionsjustlikemine.com</code>
        is the definitive source of truth for content this site references.
        Secondary sources are additive review material only. No PJLM-derived
        page, lyric, fact, asset, inventory record, or source-of-truth assertion
        is overwritten, normalized, superseded, or weakened without John's
        express authorization. See <a href="{{ '/about/' | url }}">About</a>
        and <a href="{{ '/sources/' | url }}">Sources</a>.
      </p>
    </footer>
  </body>
</html>
