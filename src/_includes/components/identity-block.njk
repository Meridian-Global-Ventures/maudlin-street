{#
  identity-block component
  ------------------------
  Maudlin Street identity panel for the gateway page. Stands in the
  place PJLM's logo1.jpg + contact image occupied (left column of the
  index two-column table), but rendered entirely in CSS — no copied
  PJLM images, no contact email reproduction. Evokes the archive
  identity feel via large display type, restrained subtitle, and a
  short source-authority status line.
#}
<section class="identity" aria-label="Site identity">
  <div class="identity__brand">
    <span class="identity__brand-line-1">Maudlin</span>
    <span class="identity__brand-line-2">Street</span>
  </div>
  <p class="identity__tagline">
    A Smiths / Morrissey research archive.<br>
    Lyric notes, discography, live history, media references.
  </p>
  <p class="identity__doctrine">
    Source authority: archived <code>passionsjustlikemine.com</code>.
    Secondary sources additive only.
  </p>
</section>
